# Beispielwerte fuer Hosting beim Landkreis
FLASK_ENV=production
NOTENAPP_HOST=0.0.0.0
NOTENAPP_PORT=5000

# In Produktion unbedingt als Secret setzen
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Beispiel: externe DB
# DATABASE_URL=postgresql+psycopg://user:pass@db-host:5432/notenapp

# Reverse Proxy
TRUST_PROXY=true
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1
PROXY_FIX_X_PREFIX=0
PREFERRED_URL_SCHEME=https

# Session/Cookies
SESSION_COOKIE_NAME=notenapp_session
# SESSION_COOKIE_DOMAIN=noten.landkreis.de

# Lokaler Tray-Betrieb
NGROK_ENABLED=false
# NGROK_DOMAIN=your-ngrok-domain.ngrok-free.dev
# NGROK_EXE=C:\\tools\\ngrok.exe

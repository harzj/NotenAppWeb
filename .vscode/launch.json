{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask (venv)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "module": "flask",
            "env": {
                "FLASK_APP": "run.py",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1"
            },
            "args": ["run", "--host=0.0.0.0", "--port=5000"],
            "jinja": true,
            "justMyCode": true
        }
    ]
}
